NODE_ENV=development
PORT=4000
HOST=0.0.0.0

MONGO_URI=mongodb://mongo:27017/quick_commerce
REDIS_URL=redis://redis:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000

# Only read by `npm run seed:admin` — bootstraps the first super_admin
# account since there's no public registration endpoint.
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@quickcommerce.com
SEED_ADMIN_PHONE=9999999999
SEED_ADMIN_PASSWORD=ChangeMe123!
