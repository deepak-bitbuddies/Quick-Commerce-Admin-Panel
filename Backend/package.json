{
  "name": "quick-commerce-backend",
  "version": "1.0.0",
  "description": "Hyperlocal 10-minute delivery platform backend (Fastify + MongoDB + Redis)",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed:admin": "tsx src/scripts/seed-admin.ts"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.0",
    "fastify": "^5.10.0",
    "ioredis": "^5.10.1",
    "mongoose": "^9.7.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
