# Client-facing API base. Defaults to "/api" in code if unset — the browser
# calls this Next.js app's own route handlers, which proxy to the real
# backend server-side. You normally don't need to set this.
NEXT_PUBLIC_API_BASE_URL=/api

# Server-only: where this app's route handlers reach the real Fastify
# backend. Never exposed to the browser bundle (no NEXT_PUBLIC_ prefix).
# BACKEND_API_URL=http://localhost:4000
BACKEND_API_URL=https://quick-commerce-admin-panel-backend.onrender.com
